<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ===== CÂMERA: PreviewView full-screen ===== -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:scaleType="fillCenter" />

    <!-- ===== OVERLAY: UI sobre a câmera ===== -->
    <FrameLayout
        android:id="@+id/layoutCameraOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Gradiente superior (escurece o topo para legibilidade) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="@drawable/gradient_top" />

        <!-- Gradiente inferior (escurece o fundo para legibilidade) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_gravity="bottom"
            android:background="@drawable/gradient_bottom" />

        <!-- Barra superior: logo + botão de logs -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutToolbar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingHorizontal="20dp"
            android:paddingTop="8dp">

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UPImagens"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:shadowColor="#88000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="4"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/btnDashboard"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:src="@drawable/ic_dashboard"
                android:background="@drawable/btn_icon_overlay"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Monitoramento e Logs"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Banner de fila de upload -->
        <LinearLayout
            android:id="@+id/layoutQueueBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_marginTop="70dp"
            android:layout_marginHorizontal="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="@drawable/queue_banner_bg"
            android:visibility="gone">

            <View
                android:id="@+id/queueDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/dot_pulse"
                android:layout_marginEnd="10dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvQueueCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fotos na fila de upload"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Continue tirando fotos normalmente"
                    android:textColor="#94A3B8"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Área inferior: status + botão de captura -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingBottom="40dp"
            android:paddingHorizontal="24dp">

            <!-- Texto de status do upload -->
            <TextView
                android:id="@+id/tvStatusTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pronto para Capturar"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:shadowColor="#AA000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="6"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvStatusDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Toque para tirar foto e enviar automaticamente"
                android:textColor="#CBD5E1"
                android:textSize="13sp"
                android:gravity="center"
                android:shadowColor="#AA000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="4"
                android:layout_marginBottom="28dp" />

            <!-- Botão de captura (shutter) -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <!-- Anel externo -->
                <View
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:background="@drawable/shutter_ring"
                    android:layout_gravity="center" />

                <!-- Botão interno -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnCapture"
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:layout_gravity="center"
                    android:background="@drawable/shutter_button"
                    android:text=""
                    android:contentDescription="Tirar Foto"
                    app:backgroundTint="@null" />

                <!-- Badge contador de fila -->
                <TextView
                    android:id="@+id/tvQueueBadge"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="2dp"
                    android:background="@drawable/badge_bg"
                    android:textColor="#000000"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:visibility="gone" />

            </FrameLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- ===== DASHBOARD: WebView sobreposto ===== -->
    <LinearLayout
        android:id="@+id/layoutDashboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#0F172A"
        android:visibility="gone">

        <!-- Toolbar do Dashboard -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#0F172A"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/tvDashboardTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Logs &amp; Monitoramento"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/btnCloseDashboard"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:src="@drawable/ic_close"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Fechar"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1E293B" />

        <android.webkit.WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- ===== SEM CONEXÃO ===== -->
    <LinearLayout
        android:id="@+id/layoutOffline"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0F172A"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginBottom="20dp"
            android:src="@drawable/ic_offline" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Sem Conexão de Rede"
            android:textColor="#F8FAFC"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            android:text="Verifique sua conexão com a internet. O upload das fotos requer conexão ativa."
            android:textColor="#94A3B8"
            android:textSize="14sp"
            android:gravity="center" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnRetry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/btn_gradient"
            app:backgroundTint="@null"
            android:text="Tentar Novamente"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textSize="15sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnOpenLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/btn_outline"
            app:backgroundTint="@null"
            android:text="Ver Logs"
            android:textColor="#F8FAFC"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textSize="15sp" />

    </LinearLayout>

    <!-- ProgressBar global (Sync inicial) -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:indeterminate="true"
        android:indeterminateTint="#6366F1"
        android:visibility="gone" />

    <!-- ===== TELA DE ERRO DE SINCRONIZAÇÃO ===== -->
    <LinearLayout
        android:id="@+id/layoutSyncError"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#DDDC2626"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginBottom="24dp"
            android:src="@android:drawable/ic_dialog_alert"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Falha na Sincronização"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvSyncErrorDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:text="Não foi possível enviar a última foto. Um alerta foi registrado."
            android:textColor="#FEF2F2"
            android:textSize="16sp"
            android:gravity="center" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDismissSyncError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/btn_outline"
            app:backgroundTint="#FFFFFF"
            android:text="Entendi"
            android:textColor="#DC2626"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textSize="16sp" />

    </LinearLayout>

</FrameLayout>
